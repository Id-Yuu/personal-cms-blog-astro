---
import MainLayout from '../../layouts/MainLayout.astro';
import Sidebar from '../../components/Sidebar.jsx';
import TopWidget from '../../components/TopWidget.jsx';

export async function getStaticPaths() {
  const postsRes = await fetch('http://localhost:4000/posts');
  const posts = await postsRes.json();

  return posts.map((post) => ({
    params: { id: post.id.toString() },
    props: { post },
  }));
}

const { post } = Astro.props;

const formattedDate = post.date
  ? new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const authorRole = post.postedByRole || null;
---

<MainLayout title={post.title}>
  <main class="main-wrapper">
    <div class="blog-post">
      <TopWidget client:load />
      <h3>{post.title}</h3>
      {(authorRole || formattedDate) && (
        <div class="post-meta">
          {authorRole && (
            <span class="post-meta-author">
              <span class="post-meta-icon">✍️</span>
              Posted by
            <span class="post-meta-role">{authorRole}</span>
            </span>
          )}
          {authorRole && formattedDate && <span class="post-meta-sep">·</span>}
          {formattedDate && (
            <span class="post-meta-date">
              <span class="post-meta-icon">📅</span>
              {formattedDate}
            </span>
          )}
        </div>
      )}
      {post.image && (
        <div class="image">
          <img src={post.image} alt={post.title} />
        </div>
      )}
      <div class="content" set:html={post.content}></div>
    </div>
  </main>
  <Sidebar client:load />
</MainLayout>