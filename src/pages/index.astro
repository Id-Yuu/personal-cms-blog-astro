---
import MainLayout from '../layouts/MainLayout.astro';
import Sidebar from '../components/Sidebar.jsx';
import PostList from '../components/PostList.jsx';
import { readFileSync } from 'fs';
import path from 'path';

// 1. Read Global Settings from db.json to get the pagination limit
let settings: Record<string, any> = { postsPerPage: 3 };
try {
  const dbRaw = readFileSync(path.join(process.cwd(), 'db.json'), 'utf-8');
  const db = JSON.parse(dbRaw);
  if (db.settings) settings = db.settings;
} catch (e) {
  console.error("Could not read settings from db.json");
}

const limit = Number(settings.postsPerPage) || 3;

// 2. Read posts from posts.json, sorted newest-first, limited to first page
let initialPosts: any[] = [];
try {
  const postsRaw = readFileSync(path.join(process.cwd(), 'posts.json'), 'utf-8');
  const allPosts = JSON.parse(postsRaw).posts ?? [];
  // Sort by id descending (id is a timestamp string), then take the first page
  initialPosts = [...allPosts]
    .sort((a, b) => Number(b.id) - Number(a.id))
    .slice(0, limit);
} catch (e) {
  console.error("Could not read posts from posts.json");
}
---

<MainLayout title="Home">
  <main class="main-wrapper">
    <PostList 
      client:load 
      initialPosts={initialPosts} 
      postsPerPage={limit} 
    />
  </main>
  
  <Sidebar client:load />
</MainLayout>