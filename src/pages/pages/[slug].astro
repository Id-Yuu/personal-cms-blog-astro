---
import MainLayout from '../../layouts/MainLayout.astro';
import Sidebar from '../../components/Sidebar.jsx';
import { readFileSync } from 'fs';
import path from 'path';

export async function getStaticPaths() {
  try {
    const dbRaw = readFileSync(path.join(process.cwd(), 'db.json'), 'utf-8');
    const pages = JSON.parse(dbRaw).pages ?? [];
    return (Array.isArray(pages) ? pages : []).map((page: any) => ({
      params: { slug: page.slug },
      props: { page },
    }));
  } catch (e) {
    return [];
  }
}

const { page } = Astro.props;
---

<MainLayout title={page.title}>
  <main class="main-wrapper">
    <article class="blog-post">
      {page.image && (
        <div class="image">
          <img src={page.image} alt={page.title} />
        </div>
      )}
      <h1>{page.title}</h1>
      <div class="post-body" set:html={page.content} />
    </article>
  </main>
  <Sidebar client:load />
</MainLayout>
