---
import '../styles/global.css';
import Header from '../components/Header.jsx';
import Nav from '../components/Nav.jsx';
import Footer from '../components/Footer.jsx';
import BackToTop from '../components/BackToTop.jsx';
import { readFileSync } from 'fs';
import path from 'path';

const { title } = Astro.props;
const currentPath = Astro.url.pathname;


// Read global settings directly from db.json (works at build time without the server)
let settings: Record<string, any> = { headerTitle: 'Blog', headerDesc: 'Loading...', footerText: '© 2025' };
try {
  const dbRaw = readFileSync(path.join(process.cwd(), 'db.json'), 'utf-8');
  const db = JSON.parse(dbRaw);
  if (db.settings) settings = db.settings;
} catch (e) {
  console.error("Could not read settings from db.json");
}

// Read dynamic pages for Nav directly from db.json
let navPages: any[] = [];
try {
  const dbRaw = readFileSync(path.join(process.cwd(), 'db.json'), 'utf-8');
  const db = JSON.parse(dbRaw);
  navPages = Array.isArray(db.pages) ? db.pages : [];
} catch (e) {
  console.error("Could not read pages from db.json");
}

let bgLayers = [];
if (settings.bodyBgImageLeft) {
  bgLayers.push(`url(${settings.bodyBgImageLeft}) ${settings.bodyBgPositionLeft || 'left top'} / ${settings.bodyBgSizeLeft || 'auto'} no-repeat`);
}
if (settings.bodyBgImageRight) {
  bgLayers.push(`url(${settings.bodyBgImageRight}) ${settings.bodyBgPositionRight || 'right top'} / ${settings.bodyBgSizeRight || 'auto'} no-repeat`);
}
const bodyBgCustom = bgLayers.length > 0 ? bgLayers.join(', ') + ', var(--bg-color)' : null;
---
<!DOCTYPE html>
<html lang="en" data-theme={settings.themeMode === 'dark' ? 'dark' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Blog</title>
    <style is:inline set:html={`
      :root {
        ${settings.headerBgImage ? `--header-bg-image: url(${settings.headerBgImage});` : ''}
        ${bodyBgCustom ? `--body-bg-custom: ${bodyBgCustom};` : ''}
      }
    `}></style>
  </head>
  <body>
    <div id="root">
      <div class="container">
        <Header title={settings.headerTitle} desc={settings.headerDesc} showHeaderTitle={settings.showHeaderTitle} />
        <Nav currentPath={currentPath} pages={navPages as never[]} />
        <div class="main">
          <slot />
        </div>
        <Footer text={settings.footerText} />
      </div>
      {settings.showBackToTop && <BackToTop client:load />}
    </div>
  </body>
</html>